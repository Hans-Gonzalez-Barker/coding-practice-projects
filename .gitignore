# ---- Python bytecode / caches ----
__pycache__/
*.py[codz]
*$py.class
*.so

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---- Packaging / build artifacts ----
build/
dist/
*.egg-info/
*.egg

# ---- Environment variables / secrets ----
.env
.envrc

# ---- Testing & coverage ----
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# ---- Type checkers / linters ----
.mypy_cache/
.ruff_cache/

# ---- Jupyter / IPython ----
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---- VS Code temp file (from Code Runner) ----
tempCodeRunnerFile.py

# ---- Local databases (from the ETL project, unless you want to commit samples) ----
*.sqlite3
*.db

# ---- Operating system junk ----
# Windows
Thumbs.db
Desktop.ini
# macOS (in case a collaborator or grader is on a Mac)
.DS_Store

# NOTE: .vscode/ is intentionally NOT ignored — the shared editor settings
#       are committed so the repo carries its own setup.
# NOTE: data files (*.csv, *.json) are intentionally NOT ignored — projects
#       keep the datasets they need alongside their code.

# ---- Claude ----
CLAUDE.md

